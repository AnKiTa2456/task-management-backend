// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║             TaskFlow — Production PostgreSQL Schema                       ║
// ║             Prisma ORM  ·  v5.x                                           ║
// ╚═══════════════════════════════════════════════════════════════════════════╝
//
// Entity map:
//   User  ──< RefreshToken
//   User  ──< TeamMember >── Team
//   User  ──< Board (owner)
//   Board ──< Column ──< Task
//   Task  ──< Comment
//   Task  ──< TaskAttachment
//   Task  ──< Activity
//   Task  >──< Label  (many-to-many via _TaskLabels)
//   Task  >──< User   (watchers, many-to-many via TaskWatcher)
//   Board ──< Activity
//   User  ──< Notification
//

// ─────────────────────────────────────────────────────────────────────────────
// Generator & Datasource
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]   // enables Postgres full-text search
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  ENUMS                                                                    ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

// Team / board membership level
enum Role {
  OWNER   // full control: delete board/team, manage all members
  ADMIN   // manage members, edit board settings
  MEMBER  // create & edit tasks
  VIEWER  // read-only access
}

// Kanban column state — drives workflow logic
enum TaskStatus {
  BACKLOG      // not yet scheduled
  TODO         // scheduled, not started
  IN_PROGRESS  // actively being worked on
  IN_REVIEW    // waiting for code review / QA
  BLOCKED      // cannot proceed until dependency resolves
  DONE         // completed
  CANCELLED    // will not be completed
}

// How urgent the task is — used for sorting and visual indicators
enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Granular event types — drives the activity feed
enum ActivityType {
  // Task lifecycle
  TASK_CREATED
  TASK_UPDATED
  TASK_MOVED        // column changed
  TASK_STATUS_CHANGED
  TASK_PRIORITY_CHANGED
  TASK_ASSIGNED
  TASK_UNASSIGNED
  TASK_DUE_DATE_SET
  TASK_DUE_DATE_REMOVED
  TASK_COMPLETED
  TASK_REOPENED
  TASK_DELETED
  TASK_RESTORED     // soft-delete restored

  // Comments
  COMMENT_ADDED
  COMMENT_EDITED
  COMMENT_DELETED

  // Attachments
  ATTACHMENT_UPLOADED
  ATTACHMENT_DELETED

  // Board
  BOARD_CREATED
  BOARD_UPDATED
  BOARD_ARCHIVED
  COLUMN_ADDED
  COLUMN_RENAMED
  COLUMN_DELETED

  // Team
  MEMBER_ADDED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED

  // Labels
  LABEL_ADDED_TO_TASK
  LABEL_REMOVED_FROM_TASK
}

// What kind of file was attached
enum AttachmentType {
  IMAGE     // jpg, png, gif, webp
  DOCUMENT  // pdf, doc, docx
  SPREADSHEET
  VIDEO
  ARCHIVE   // zip, tar
  OTHER
}

// Notification delivery state
enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  MODELS                                                                   ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

// ─────────────────────────────────────────────────────────────────────────────
// USER
// Central identity entity. One user can belong to many teams and own
// many boards. Sensitive fields (passwordHash) never selected by default.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  // ── Identity ──────────────────────────────────────────────────────────────
  id           String   @id @default(cuid())
  email        String   @unique
  name         String   @db.VarChar(120)
  passwordHash String   // bcrypt, never exposed via API

  // ── Profile ───────────────────────────────────────────────────────────────
  avatarUrl    String?  @db.Text
  bio          String?  @db.VarChar(500)
  timezone     String   @default("UTC") @db.VarChar(60)

  // ── Account state ─────────────────────────────────────────────────────────
  isActive          Boolean   @default(true)
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?   @unique  // set during registration, cleared on verify
  passwordResetToken String?  @unique
  passwordResetExpiry DateTime?

  // ── Timestamps ────────────────────────────────────────────────────────────
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // ── Relations ─────────────────────────────────────────────────────────────
  refreshTokens  RefreshToken[]
  teamMembers    TeamMember[]
  ownedBoards    Board[]
  createdTasks   Task[]         @relation("TaskCreator")
  assignedTasks  Task[]         @relation("TaskAssignee")
  comments       Comment[]
  activities     Activity[]
  notifications  Notification[]
  watchedTasks        TaskWatcher[]
  uploadedAttachments TaskAttachment[]

  // ── Indexes ───────────────────────────────────────────────────────────────
  // email is already indexed via @unique
  @@index([isActive])
  @@index([createdAt(sort: Desc)])

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// REFRESH TOKEN
// Stored server-side for rotation validation. One-time use: deleted on refresh.
// Multiple rows per user = supports multi-device login.
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique @db.Text  // hashed in production
  deviceInfo String?  @db.VarChar(255)  // "Chrome on macOS" — for UI display
  ipAddress  String?  @db.VarChar(45)   // IPv4 or IPv6
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  // ── FK ────────────────────────────────────────────────────────────────────
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([userId])
  @@index([expiresAt])  // cleanup job: DELETE FROM refresh_tokens WHERE expires_at < NOW()

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// TEAM
// Workspace that groups users and boards together.
// ─────────────────────────────────────────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(80)
  slug        String   @unique @db.VarChar(80)  // URL-safe identifier
  description String?  @db.VarChar(500)
  avatarUrl   String?  @db.Text
  isPersonal  Boolean  @default(false) // auto-created team for solo users

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── Relations ─────────────────────────────────────────────────────────────
  members     TeamMember[]
  boards      Board[]

  // ── Indexes ───────────────────────────────────────────────────────────────
  // slug is already indexed via @unique
  @@index([createdAt(sort: Desc)])

  @@map("teams")
}

// ─────────────────────────────────────────────────────────────────────────────
// TEAM MEMBER  (User ↔ Team junction with role)
// ─────────────────────────────────────────────────────────────────────────────

model TeamMember {
  id       String   @id @default(cuid())
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())

  // ── FK ────────────────────────────────────────────────────────────────────
  userId   String
  teamId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // ── Constraints ───────────────────────────────────────────────────────────
  @@unique([userId, teamId])  // one role per user per team

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([teamId, role])  // "list all admins of team X"

  @@map("team_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// BOARD
// Represents a project / sprint. Contains ordered columns.
// Supports both team boards and personal boards (teamId = null).
// ─────────────────────────────────────────────────────────────────────────────

model Board {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  background  String?  @db.VarChar(100)  // hex color or image URL
  isPrivate   Boolean  @default(false)
  isArchived  Boolean  @default(false)
  archivedAt  DateTime?

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── FK ────────────────────────────────────────────────────────────────────
  ownerId     String
  teamId      String?
  owner       User    @relation(fields: [ownerId], references: [id])
  team        Team?   @relation(fields: [teamId], references: [id])

  // ── Relations ─────────────────────────────────────────────────────────────
  columns     Column[]
  labels      Label[]
  activities  Activity[]

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([ownerId])
  @@index([teamId])
  @@index([isArchived, updatedAt(sort: Desc)])  // "active boards, recently updated first"

  @@map("boards")
}

// ─────────────────────────────────────────────────────────────────────────────
// COLUMN
// Ordered stage within a board (e.g. "To Do", "In Progress").
// Tasks belong to one column at a time.
// ─────────────────────────────────────────────────────────────────────────────

model Column {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(60)
  position    Int                         // 0-based ordering within board
  color       String? @db.VarChar(7)      // hex, e.g. "#6366f1"
  taskLimit   Int?                        // WIP limit — null means unlimited
  isDefault   Boolean @default(false)     // auto-selected when creating a task

  // ── FK ────────────────────────────────────────────────────────────────────
  boardId     String
  board       Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  // ── Relations ─────────────────────────────────────────────────────────────
  tasks       Task[]

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([boardId, position])  // critical for rendering column order

  @@map("columns")
}

// ─────────────────────────────────────────────────────────────────────────────
// TASK
// Core entity of the system. Belongs to a column, has one assignee,
// many comments, labels, attachments, and an activity history.
// Supports soft-delete via deletedAt.
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  // ── Identity ──────────────────────────────────────────────────────────────
  id          String     @id @default(cuid())
  title       String     @db.VarChar(255)
  description String?    @db.Text         // markdown supported

  // ── Status & priority enums ───────────────────────────────────────────────
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)

  // ── Ordering (drag-and-drop) ──────────────────────────────────────────────
  position    Int        @default(0)      // position within parent column

  // ── Dates ─────────────────────────────────────────────────────────────────
  dueDate     DateTime?
  startDate   DateTime?                  // optional planned start
  completedAt DateTime?                  // set when status → DONE

  // ── Story points (agile estimation) ───────────────────────────────────────
  storyPoints Int?

  // ── Soft delete ───────────────────────────────────────────────────────────
  deletedAt   DateTime?                  // null = active, non-null = deleted

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // ── FK ────────────────────────────────────────────────────────────────────
  columnId    String
  creatorId   String
  assigneeId  String?

  column      Column     @relation(fields: [columnId],   references: [id], onDelete: Cascade)
  creator     User       @relation("TaskCreator",  fields: [creatorId],  references: [id])
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])

  // ── Relations ─────────────────────────────────────────────────────────────
  comments    Comment[]
  attachments TaskAttachment[]
  labels      Label[]         @relation("TaskLabels")
  activities  Activity[]
  watchers    TaskWatcher[]

  // ── Indexes ───────────────────────────────────────────────────────────────

  // Most critical — renders the board
  @@index([columnId, position])

  // Dashboard / "My Tasks" queries
  @@index([assigneeId, status])
  @@index([assigneeId, dueDate])

  // Search & filter
  @@index([status])
  @@index([priority])
  @@index([dueDate])

  // Soft-delete — most queries add WHERE deleted_at IS NULL
  @@index([deletedAt])

  // Created-by queries
  @@index([creatorId])

  // Composite: filter tasks by status + priority on a board
  @@index([columnId, status, priority])

  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// TASK WATCHER  (User ↔ Task many-to-many)
// Users who want notifications for a task they didn't create or aren't assigned.
// ─────────────────────────────────────────────────────────────────────────────

model TaskWatcher {
  id         String   @id @default(cuid())
  watchedAt  DateTime @default(now())

  // ── FK ────────────────────────────────────────────────────────────────────
  userId     String
  taskId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  task       Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // ── Constraints ───────────────────────────────────────────────────────────
  @@unique([userId, taskId])

  @@map("task_watchers")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMENT
// Threaded discussion on a task. Supports soft-delete so the thread
// structure is preserved even when a comment is removed.
// ─────────────────────────────────────────────────────────────────────────────

model Comment {
  id        String    @id @default(cuid())
  content   String    @db.Text         // markdown
  isEdited  Boolean   @default(false)  // true once any edit has been saved

  // ── Soft delete ───────────────────────────────────────────────────────────
  deletedAt DateTime?                  // "This comment was deleted" pattern

  // ── Threading (optional) ──────────────────────────────────────────────────
  parentId  String?                    // null = top-level comment
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // ── FK ────────────────────────────────────────────────────────────────────
  taskId    String
  authorId  String
  task      Task   @relation(fields: [taskId],   references: [id], onDelete: Cascade)
  author    User   @relation(fields: [authorId], references: [id])

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([taskId, createdAt])          // fetch all comments for a task, oldest first
  @@index([authorId])
  @@index([parentId])                   // fetch replies for a comment
  @@index([deletedAt])                  // filter soft-deleted

  @@map("comments")
}

// ─────────────────────────────────────────────────────────────────────────────
// TASK ATTACHMENT
// Files uploaded to a task. Metadata stored in DB; actual binary stored in
// object storage (S3 / R2). storageKey is the object path in that bucket.
// ─────────────────────────────────────────────────────────────────────────────

model TaskAttachment {
  id           String         @id @default(cuid())

  // ── File metadata ─────────────────────────────────────────────────────────
  filename     String         @db.VarChar(255)  // original user filename
  storageKey   String         @unique @db.Text  // "uploads/taskId/uuid.pdf"
  mimeType     String         @db.VarChar(127)  // "application/pdf"
  sizeBytes    Int                              // file size — used for quota checks
  type         AttachmentType @default(OTHER)

  // ── Preview ───────────────────────────────────────────────────────────────
  thumbnailKey String?        @db.Text          // object path for generated thumbnail
  width        Int?                             // for images/videos
  height       Int?

  // ── Soft delete ───────────────────────────────────────────────────────────
  deletedAt    DateTime?

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt    DateTime       @default(now())

  // ── FK ────────────────────────────────────────────────────────────────────
  taskId       String
  uploaderId   String
  task         Task   @relation(fields: [taskId],     references: [id], onDelete: Cascade)
  uploader     User   @relation(fields: [uploaderId], references: [id])

  // ── Relations ─────────────────────────────────────────────────────────────
  activities   Activity[]

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([taskId])                     // "all attachments for this task"
  @@index([uploaderId])
  @@index([type])                       // "all images on this board"
  @@index([deletedAt])

  @@map("task_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// LABEL
// Board-scoped coloured tags applied to tasks (many-to-many via _TaskLabels).
// ─────────────────────────────────────────────────────────────────────────────

model Label {
  id      String   @id @default(cuid())
  name    String   @db.VarChar(40)
  color   String   @db.VarChar(7)   // hex, e.g. "#10b981"

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())

  // ── FK ────────────────────────────────────────────────────────────────────
  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  // ── Relations ─────────────────────────────────────────────────────────────
  tasks   Task[] @relation("TaskLabels")  // Prisma implicit many-to-many

  // ── Constraints ───────────────────────────────────────────────────────────
  @@unique([boardId, name])   // no duplicate label names per board

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([boardId])

  @@map("labels")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITY
// Append-only audit log. Never updated or deleted (except cascades).
// metadata is a flexible JSON field for event-specific data.
// ─────────────────────────────────────────────────────────────────────────────

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType

  // ── Flexible event payload ─────────────────────────────────────────────────
  // Examples:
  //   TASK_MOVED:          { fromColumn: "Todo", toColumn: "In Progress" }
  //   TASK_PRIORITY_CHANGED: { from: "LOW", to: "URGENT" }
  //   ATTACHMENT_UPLOADED: { filename: "spec.pdf", sizeBytes: 204800 }
  metadata  Json         @default("{}")  @db.JsonB

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt DateTime     @default(now())  // immutable — never updated

  // ── FK (all nullable — activity survives deletion of related entities) ─────
  userId       String
  taskId       String?
  boardId      String?
  attachmentId String?

  user       User            @relation(fields: [userId],       references: [id])
  task       Task?           @relation(fields: [taskId],       references: [id], onDelete: SetNull)
  board      Board?          @relation(fields: [boardId],      references: [id], onDelete: SetNull)
  attachment TaskAttachment? @relation(fields: [attachmentId], references: [id], onDelete: SetNull)

  // ── Indexes ───────────────────────────────────────────────────────────────

  // Primary access pattern: board activity feed, newest first
  @@index([boardId, createdAt(sort: Desc)])

  // Task timeline
  @@index([taskId, createdAt(sort: Desc)])

  // User activity history
  @@index([userId, createdAt(sort: Desc)])

  // Filter by event type
  @@index([type])

  @@map("activities")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION
// In-app notifications delivered to specific users. Decoupled from Activity
// so one activity can fan-out to many user notifications (assignee, watchers).
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String             @id @default(cuid())
  title     String             @db.VarChar(160)
  body      String?            @db.VarChar(500)

  // ── State ─────────────────────────────────────────────────────────────────
  status    NotificationStatus @default(UNREAD)
  readAt    DateTime?

  // ── Deep link ─────────────────────────────────────────────────────────────
  // Relative URL the user should navigate to when clicking the notification
  actionUrl String?            @db.VarChar(500)

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt DateTime           @default(now())

  // ── FK ────────────────────────────────────────────────────────────────────
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Indexes ───────────────────────────────────────────────────────────────

  // Most common query: "unread notifications for user X, newest first"
  @@index([userId, status, createdAt(sort: Desc)])

  // Cleanup: archive/delete old read notifications
  @@index([status, createdAt])

  @@map("notifications")
}
