# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/taskflow?schema=public"

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-32-char-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-32-char-secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Throttle (rate limiting) ────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
